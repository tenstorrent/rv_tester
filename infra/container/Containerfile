ARG CONTAINER_HUB
FROM ${CONTAINER_HUB}/riscv/dv/compiler-tools-container:bfefc2f477e0598333d4b7a16f20f1e4209ba02dbd635344366d4a9d34bd94ad as risc-p-cores/base
# supreme hack to rename root to not show up as root in external license servers
RUN sed -i 's/\broot\b/risc-p-cores/g' /etc/passwd /etc/shadow /etc/group /etc/gshadow \
    && mv /root /risc-p-cores

FROM risc-p-cores/base as risc-p-cores/riscv-gnu-toolchain
COPY ./opt/riscv /opt/riscv/

FROM risc-p-cores/base as risc-p-cores/verible
RUN mkdir -p /opt/verible && curl -sSL https://github.com/chipsalliance/verible/releases/download/v0.0-3946-g851d3ff4/verible-v0.0-3946-g851d3ff4-linux-static-x86_64.tar.gz | tar xvzf - --strip-components=1 -C /opt/verible

FROM risc-p-cores/base as risc-p-cores/repo
COPY ./repo /opt/repo

# https://aus-gitlab.local.tenstorrent.com/riscv/forks/bazel-remote/container_registry/8
FROM ${CONTAINER_HUB}/riscv/forks/bazel-remote:daa673bed809519728c2c687e3f2f905921a226c as bazel-remote

FROM risc-p-cores/base as risc-p-cores/slang
ARG SLANG_VERSION=9.0
WORKDIR /opt
RUN yum --enablerepo=powertools -y install cmake python3
RUN curl -fsSL "https://github.com/MikePopoloski/slang/archive/refs/tags/v${SLANG_VERSION}.tar.gz" \
    | tar -xvzf -
# get a version of g++ that works for the slang build
RUN source /opt/rh/gcc-toolset-12/enable \
    && cmake -S /opt/slang-${SLANG_VERSION} -B /opt/slang-build -DCMAKE_BUILD_TYPE=Release \
    && cmake --build /opt/slang-build -j"$(nproc)"

FROM risc-p-cores/base as risc-p-cores/dev

RUN yum install -y epel-release


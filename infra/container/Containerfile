ARG VERILOG_PERL_SHA=4e47bf9087c12c3f9e2a300c1ff7a4e547b578c9
RUN curl -ssL https://aus-gitlab.local.tenstorrent.com/opensrc/opensrc-verilog-perl/-/archive/${VERILOG_PERL_SHA}/verilog-perl-${VERILOG_PERL_SHA}.tar.bz2 \
    | tar xvjf -; \
    cd opensrc-verilog-perl-${VERILOG_PERL_SHA} && perl Makefile.PL && make && make install

# Install Bazel 6.5.0
ARG BAZEL_VERSION_6=6.5.0
ARG BAZEL_INSTALLER_URL_6=https://github.com/bazelbuild/bazel/releases/download/${BAZEL_VERSION_6}/bazel-${BAZEL_VERSION_6}-installer-linux-x86_64.sh

RUN curl -o bazel-6-installer.sh -sSL ${BAZEL_INSTALLER_URL_6} \
    && chmod +x bazel-6-installer.sh                           \
    && ./bazel-6-installer.sh --prefix=/usr/local/bazel-6.5.0  \
    && rm bazel-6-installer.sh

# Install Bazel 7.7.1
ARG BAZEL_VERSION_7=7.7.1
ARG BAZEL_INSTALLER_URL_7=https://github.com/bazelbuild/bazel/releases/download/${BAZEL_VERSION_7}/bazel-${BAZEL_VERSION_7}-installer-linux-x86_64.sh

RUN curl -o bazel-7-installer.sh -sSL ${BAZEL_INSTALLER_URL_7} \
    && chmod +x bazel-7-installer.sh                           \
    && ./bazel-7-installer.sh --prefix=/usr/local/bazel-7.7.1  \
    && rm bazel-7-installer.sh

# Install Bazel 8.5.0
ARG BAZEL_VERSION_8=8.5.0
ARG BAZEL_INSTALLER_URL_8=https://github.com/bazelbuild/bazel/releases/download/${BAZEL_VERSION_8}/bazel-${BAZEL_VERSION_8}-installer-linux-x86_64.sh

RUN curl -o bazel-8-installer.sh -sSL ${BAZEL_INSTALLER_URL_8} \
    && chmod +x bazel-8-installer.sh                           \
    && ./bazel-8-installer.sh --prefix=/usr/local/bazel-8.5.0  \
    && rm bazel-8-installer.sh

# Create symlinks for all versions in /usr/local/bin
RUN ln -s /usr/local/bazel-6.5.0/bin/bazel /usr/local/bin/bazel-6.5.0 \
    && ln -s /usr/local/bazel-7.7.1/bin/bazel /usr/local/bin/bazel-7.7.1 \
    && ln -s /usr/local/bazel-8.5.0/bin/bazel /usr/local/bin/bazel-8.5.0 \
    && ln -s /usr/local/bin/bazel-6.5.0 /usr/local/bin/bazel-6 \
    && ln -s /usr/local/bin/bazel-7.7.1 /usr/local/bin/bazel-7 \
    && ln -s /usr/local/bin/bazel-8.5.0 /usr/local/bin/bazel-8 \
    && ln -s /usr/local/bin/bazel-6.5.0 /usr/local/bin/bazel \
    && bazel version

RUN useradd --uid 1000 _replaceme
RUN chmod go+w /etc/passwd
RUN su -c "bazel version" - _replaceme
RUN su -c "bazel-7 version" - _replaceme
RUN su -c "bazel-8 version" - _replaceme
RUN chmod go+rwx /home/_replaceme /home/_replaceme/.cache/bazel

COPY --from=risc-p-cores/riscv-gnu-toolchain /opt/riscv /usr/local
COPY --from=risc-p-cores/verible /opt/verible /usr/local
COPY --from=risc-p-cores/repo /opt/repo /usr/local
COPY --from=bazel-remote       /opt/bazel-remote                  /usr/local
COPY --from=risc-p-cores/slang /opt/slang-build/bin/slang /usr/local/bin/slang

WORKDIR /work

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["bash"]

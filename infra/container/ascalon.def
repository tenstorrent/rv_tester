
Bootstrap: docker
From: rockylinux:8.5 
Stage: devel

%setup
set -eux

USR_LOCAL="${SINGULARITY_ROOTFS}/usr/local"

rsync -a /tools_risc/opensrc/riscv-toolchain-08-30-22/newlib ${USR_LOCAL} --files-from - <<'EOF'
bin/riscv64-unknown-elf-as
bin/riscv64-unknown-elf-g++
bin/riscv64-unknown-elf-gcc
bin/riscv64-unknown-elf-objcopy
bin/riscv64-unknown-elf-objdump
bin/riscv64-unknown-elf-readelf
riscv64-unknown-elf/bin/as
riscv64-unknown-elf/bin/ld
riscv64-unknown-elf/bin/ld.bfd
riscv64-unknown-elf/lib/libm.a
libexec/gcc/riscv64-unknown-elf/12.1.0/cc1
libexec/gcc/riscv64-unknown-elf/12.1.0/cc1plus
libexec/gcc/riscv64-unknown-elf/12.1.0/liblto_plugin.so
lib/gcc/riscv64-unknown-elf/12.1.0/libgcc.a
EOF

rsync -a /tools_risc/opensrc/riscv-toolchain-08-30-22/newlib/ ${USR_LOCAL} --include-from - --exclude='*' <<'EOF'
lib/
lib/gcc/
lib/gcc/riscv64-unknown-elf/
lib/gcc/riscv64-unknown-elf/12.1.0/
lib/gcc/riscv64-unknown-elf/12.1.0/include/
lib/gcc/riscv64-unknown-elf/12.1.0/include/*.h
lib/gcc/riscv64-unknown-elf/12.1.0/include-fixed/
lib/gcc/riscv64-unknown-elf/12.1.0/include-fixed/*.h
lib/gcc/riscv64-unknown-elf/12.1.0/rv64i/
lib/gcc/riscv64-unknown-elf/12.1.0/rv64i/lp64/
lib/gcc/riscv64-unknown-elf/12.1.0/rv64i/lp64/*.o
lib/gcc/riscv64-unknown-elf/12.1.0/rv64i/lp64/*.a
riscv64-unknown-elf/
riscv64-unknown-elf/include/
riscv64-unknown-elf/include/*.h
riscv64-unknown-elf/include/machine/
riscv64-unknown-elf/include/machine/*.h
riscv64-unknown-elf/include/sys/
riscv64-unknown-elf/include/sys/*.h
EOF

cp /tools_risc/tt/bazel-remote/2a190a646a007cb8c691749aa5edb7005a31fbb6/bin/bazel-remote ${USR_LOCAL}/bin

curl -sSL https://github.com/chipsalliance/verible/releases/download/v0.0-1789-g43d1b6fe/verible-v0.0-1789-g43d1b6fe-CentOS-8.4.2105-na-x86_64.tar.gz | tar xvzf - --strip-components=1 -C ${USR_LOCAL}

%post

yum install -y epel-release

yum --enablerepo=powertools -y install \
bc                                     \
libnsl                                 \
perl                                   \
dtc                                    \
make                                   \
which                                  \
java-devel                             \
ksh                                    \
unzip                                  \
time                                   \
python39                               \
python2                                \
emacs                                  \
libXScrnSaver                          \
numactl-libs                           \
boost                                  \
boost-devel                            \
libpng12                               \
hdf5-devel                             \
ninja-build                            \
socat                                  \
compat-openssl10                       \
patch                                  \
libpng12                               \
csh                                    \
langpacks-en                           \
ncurses-compat-libs                    \
postgresql-libs                        \
gcc-toolset-11                         \
git

source scl_source enable gcc-toolset-11

alternatives --set python $(which python2)
python3 -m pip install pandas                                  \
sqlalchemy                                                     \
pymysql                                                        \
pyyaml                                                         \
typing                                                         \
lxml                                                           \
openpyxl                                                       \
systemrdl-compiler==1.23.0                                     \
peakrdl-uvm                                                    \
pytest                                                         \
prettytable                                                    \
sortedcontainers                                               \
sharepy                                                        \
psutil                                                         \
pyvsc                                                          \
cryptography                                                   \
pika                                                           \
xmltodict                                                      \
bitstring                                                      \
zstd                                                           \
https://github.com/darshakk/banyan/archive/refs/heads/main.zip

curl -ssL https://downloads.mariadb.com/MariaDB/mariadb_repo_setup | bash;  \
yum -y install MariaDB-shared MariaDB-devel python39-devel;                 \
python3 -m pip install mariadb


BAZEL_VERSION=6.0.0
BAZEL_INSTALLER_URL=https://github.com/bazelbuild/bazel/releases/download/${BAZEL_VERSION}/bazel-${BAZEL_VERSION}-installer-linux-x86_64.sh

curl -o bazel-installer.sh -sSL ${BAZEL_INSTALLER_URL} \
&& chmod +x bazel-installer.sh                         \
&& ./bazel-installer.sh                                \
&& rm bazel-installer.sh                               \
&& bazel version

%environment
export CONTAINER_ENTRYPOINT_DONT_CHANGE_ENV=
export DISPLAY=

%runscript

if [ -z ${CONTAINER_ENTRYPOINT_DONT_CHANGE_ENV+x} ]; then

    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin
    export LD_LIBRARY_PATH=

fi

source scl_source enable gcc-toolset-11

exec -- "$@"

%startscript

if [ -z ${CONTAINER_ENTRYPOINT_DONT_CHANGE_ENV+x} ]; then

    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin
    export LD_LIBRARY_PATH=

fi

source scl_source enable gcc-toolset-11
ulimit -s unlimited

exec -- "$@"

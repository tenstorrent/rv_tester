#!/usr/bin/python3

from test.util import testdir, mkpath_tree_fatal
import argparse
import datetime
import logging
import multiprocessing
import os
import prettytable
import re
import subprocess
import sys
import time

class Target():
    def __init__(self, name, result_dir, stdout, stderr):
        self.name       = name
        self.result_dir = result_dir
        self.stdout     = stdout
        self.stderr     = stderr
        self.start      = datetime.datetime.now()
        self.end        = datetime.datetime.now()

    def set_start(self):
        self.start = datetime.datetime.now()

    def set_end(self):
        self.end = datetime.datetime.now()

def parse_args():
    arg_parser = argparse.ArgumentParser()
    
    arg_parser.add_argument('--target',
        action      = 'append',
        metavar     = '',
        required    = True,
        help        = '''The target name to be run.
This option can be supplied multiple times to run all make targets in parallel.
'''
    )
    arg_parser.add_argument('--only',
        action  = 'store',
        metavar = '',
        help    = '''The target matching this regex will be run.
Targets not matching this regex string will not be run.
'''
    )
    arg_parser.add_argument('--but_not',
        action  = 'store',
        metavar = '',
        help    = '''The target matching this regex will be excluded to run.
Targets not matching this regex string will be run.
'''
    )
    arg_parser.add_argument('--parallel',
        action  = 'store',
        type    = int,
        metavar = '',
        default = 10,
        help    = '''The number of parallel runs. Default 10'''
    )
    arg_parser.add_argument('--longest_running',
        action  = 'store',
        type    = int,
        metavar = '',
        default = 5,
        help    = '''The number of entries printed in longest running stats. Default 5'''
    )
    
    return arg_parser.parse_args()

def run_target(target):
    target.set_start()
    stdout_fh = open( target.stdout, 'w' )
    stderr_fh = open( target.stderr, 'w' )
    cp = subprocess.run(
        'make ' + target.name,
        shell = True,
        stdout = stdout_fh,
        stderr = stderr_fh,
    )
    target.set_end()
    if cp.returncode != 0:
        raise Exception('target {} failed'. format(target.name))

def main():
    logging.basicConfig(
        format  = '[%(levelname)s] %(asctime)s - %(message)s',
        level   = logging.INFO,
        stream  = sys.stdout,
    )
    logger = logging.getLogger()

    args = parse_args()
    targets = []
    for target in args.target:
       if args.only is not None and not bool(re.search(args.only, target)):
            continue

       if args.but_not is not None and bool(re.search(args.but_not, target)):
            continue

       targets.append(target)

    if len(targets) == 0:
        raise Exception('No targets to run')
        return

    pool_size = args.parallel
    if len(targets) < pool_size:
        pool_size = len(targets)

    base_dir = testdir()
    mkpath_tree_fatal(base_dir, {})

    target_objs = []
    for target in targets:
        result_dir  = os.path.join(base_dir, target)
        stdout      = os.path.join(result_dir, 'stdout')
        stderr      = os.path.join(result_dir, 'stderr')

        mkpath_tree_fatal(result_dir, {})
        target_objs.append(Target(target, result_dir, stdout, stderr))

    target_result = {}
    total   = len(targets)
    ready   = 0
    failed  = 0
    with multiprocessing.Pool(pool_size) as pool:
        for target in target_objs:
            res = pool.apply_async(run_target, (target,))
            target_result[target] = res

        completed = False
        while not completed:
            ready = 0
            failed = 0
            logger.info('Targets Total: {0} Completed: {1} Failed: {2}'.format(total, ready, failed)) 
            
            completed = True
            for target in target_objs:
                if not target_result[target].ready():
                    completed = False
                else:
                    ready += 1
                    if not target_result[target].successful():
                        failed += 1

            time.sleep(5)


    logger.info('Targets Total: {0} Completed: {1} Failed: {2}'.format(total, ready, failed)) 

    target_runtimes = []

    pt = prettytable.PrettyTable()
    pt.field_names = ['Target', 'Status', 'Time Taken (s)']
    for target in target_objs:
        status = 'fail'
        if target_result[target].successful():
            status = 'pass'
        time_taken = (target.end - target.start).total_seconds()

        pt.add_row([target.name, status, time_taken])
        target_runtimes.append({
            'name': target.name,
            'runtime': time_taken,
        })

    print(pt)
    logger.info(f'result base_dir: {base_dir}')
    print()

    target_runtimes = sorted(target_runtimes, key = lambda x: x['runtime'], reverse = True)
    if len(target_runtimes) > args.longest_running:
        target_runtimes = target_runtimes[:args.longest_running]

    pt = prettytable.PrettyTable()
    pt.field_names = ['Target', 'Time Taken (s)']
    for entry in target_runtimes:
        pt.add_row([entry['name'], entry['runtime']])

    logger.info('Longest running targets:')
    print(pt)

    if failed > 0:
        raise Exception('Total {0} targets failed.'.format(failed))

if __name__ == '__main__':
    main()

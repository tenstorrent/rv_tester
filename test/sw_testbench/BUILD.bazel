load("@cvm//:defs.bzl", "topology_gen")
load("@rv_tester//bazel:defs.bzl", "rv_tester_gen")

# memmap.json + whisper.json are passed via plusargs to the smoke binaries
# (testlists need them by file label). sw_tb.cpp goes through exports_files
# rather than a cc_library because it `#include "Vtop.h"` — the
# verilator-generated header is per-harness, so each sw_<N>c_tb_verilator
# cc_binary needs its own compile against its own veri_lib output.
exports_files(
    ["memmap.json", "sw_tb.cpp", "whisper.json", "pulp_platform_verilator_waiver.vlt"],
    visibility = ["//visibility:public"],
)

exports_files(
    ["top.sv", "harness_undefines.sv"],
    visibility = ["//test/sw_testbench/verilator:__pkg__"],
)

cc_library(
    name = "dpi_glue",
    srcs = ["dpi.cpp", "gflags.cpp"],
    deps = ["@cvm//:plusargs"],
    alwayslink = True,
    linkstatic = True,
    visibility = ["//test/sw_testbench/verilator:__pkg__"],
)

harnesses = ["sw_1c", "sw_2c"]

[
    [
        genrule(
            name = name + "_harness_define",
            outs = [name + "_harness_defines.sv"],
            cmd = "echo '`define HARNESS {}' > $@".format(name.upper()),
            visibility = ["//test/sw_testbench/verilator:__pkg__"],
        ),

        topology_gen(
            name = name + "_topology",
            srcs = [
                "@rv_tester//src/transactors/axi_sw:axi_sw_attrs.yml",
                name + "_rv_tester_platform.yml",
                name + "_rv_tester_hart.yml",
                "rv_tester_axi.yml",
                "@rv_tester//src:rv_tester_topology",
                name + "_topology.yml",
            ],
        ),

        rv_tester_gen(
            name = name + "_rv_tester",
            topology = name + "_topology",
            csr_spec = "@rv_tester//scripts/csr:csr_spec",
            project_overrides = "@rv_tester//scripts:project_overrides",
            pmu_spec = "@rv_tester//src/pmu:pmu_spec",
            cc_attrs = {
                "alwayslink": True,
                "linkstatic": True,
            },
            visibility = ["//test/sw_testbench/verilator:__pkg__"],
        ),
    ]
    for name in harnesses
]

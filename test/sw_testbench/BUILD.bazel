load("@rules_hdl//verilog:providers.bzl", "verilog_library")
load("@rules_verilator//verilator:defs.bzl", "verilator_cc_library")
load("@cvm//:defs.bzl", "topology_gen", "packet_gen")
load("@rv_tester//bazel:defs.bzl", "rv_tester_gen")

exports_files(["pulp_platform_verilator_waiver.vlt"])

verilator_defines = [
    "+define+DMI_TB_WRITES_UNSUPPORTED",
    "+define+TRACE_CHECKS_UNSUPPORTED",
    "--default-language",
    "1800-2017",
]

harnesses = ["sw_1c", "sw_2c"]

filegroup(
    name = "vcs_waiver",
    srcs = ["sw_testbench_vcs_waiver.config"],
)

[
    [
        genrule(
            name = name + "_harness_define",
            outs = [name + "_harness_defines.sv"],
            cmd = "echo '`define HARNESS {}' > $@".format(name.upper()),
        ),

        # Replaces bzsim's verilog_dpi_library macro (which was just cc_library
        # + alwayslink + svdpi). svdpi comes via @rules_verilator's runtime.
        cc_library(
            name = name + "_dpi",
            srcs = ["dpi.cpp", "gflags.cpp"],
            deps = [
                name + "_rv_tester_dpi",
                "@cvm//:plusargs",
                "@rules_verilator//verilator:verilated_runtime",
            ],
            alwayslink = True,
            linkstatic = True,
        ),

        topology_gen(
            name = name + "_topology",
            srcs = [
                "@rv_tester//src/transactors/axi_sw:axi_sw_attrs.yml",
                name + "_rv_tester_platform.yml",
                name + "_rv_tester_hart.yml",
                "rv_tester_axi.yml",
                "@rv_tester//src:rv_tester_topology",
                name + "_topology.yml",
            ],
        ),

        rv_tester_gen(
            name = name + "_rv_tester",
            topology = name + "_topology",
            csr_spec = "@rv_tester//scripts/csr:csr_spec",
            project_overrides = "@rv_tester//scripts:project_overrides",
            pmu_spec = "@rv_tester//src/pmu:pmu_spec",
            cc_attrs = {
                "alwayslink": True,
                "linkstatic": True,
            },
        ),

        verilog_library(
            name = name + "_top",
            srcs = [
                name + "_harness_define",
                "top.sv",
                "harness_undefines.sv",
            ],
            deps = [name + "_rv_tester_sv"],
            top_module = "top",
        ),

        # Replaces bzsim's verilog_unit macro (which produced verilator views,
        # lint targets, multi-simulator binaries). Verilator-only flat shape.
        verilator_cc_library(
            name = name + "_tb_veri_lib",
            module = ":" + name + "_top",
            vopts = verilator_defines,
        ),

        cc_binary(
            name = name + "_tb_verilator",
            srcs = ["sw_tb.cpp"],
            deps = [
                ":" + name + "_tb_veri_lib",
                ":" + name + "_dpi",
                "@cvm//:logger",
                "@cvm//:topology",
            ],
        ),
    ]
    for name in harnesses
]

# Composite smoke target that drives the per-testlist test_suites.
test_suite(
    name = "all_smoke",
    tests = [
        "//test/sw_testbench/testlists:all_smoke",
        "//src/transactors/axi_sw/test/testlists:all_smoke",
        "//test/rv_tester_delay_resp_tb/testlists:all_smoke",
    ],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "whisper_json",
    srcs = ["whisper.json"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "memmap_json",
    srcs = ["memmap.json"],
    visibility = ["//visibility:public"],
)

exports_files(["sw_tb.cpp"])

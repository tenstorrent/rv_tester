load("@rules_hdl//verilog:providers.bzl", "verilog_library")
load("@rules_verilator//verilator:defs.bzl", "verilator_cc_library")

verilog_library(
    name = "rv_tester_delay_resp_tb",
    srcs = [
        ":rv_tester_delay_resp_tb_top.sv",
        ":rv_tester_delay_resp_tb_check.sv",
        ":rv_tester_delay_resp_wrapper.sv",
    ],
    deps = [
        "//src:rv_tester_delay_resp",
        "//src:rv_tester_lib",
        # Vendored axi/typedef.svh subset in lieu of @opensrc-axi.
        "//third_party/axi:typedef",
    ],
    top_module = "rv_tester_delay_resp_tb_top",
    visibility = ["//visibility:public"],
)

# Replaces bzsim's verilog_unit (multi-simulator builder) with the cvm-style
# native verilator binary. Same pattern as //sw_testbench:sw_1c_tb_verilator.
verilator_cc_library(
    name = "rv_tester_delay_resp_tb_veri_lib",
    module = ":rv_tester_delay_resp_tb",
)

cc_binary(
    name = "rv_tester_delay_resp_tb_verilator",
    srcs = ["rv_tester_delay_resp_tb_top.cpp"],
    deps = [
        ":rv_tester_delay_resp_tb_veri_lib",
        "@rules_verilator//verilator:verilated_runtime",
    ],
)

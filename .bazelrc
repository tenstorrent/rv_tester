build --cxxopt=-std=c++20 --host_cxxopt=-std=c++20
build --action_env=CC=clang --action_env=CXX=clang++ --host_action_env=CC=clang --host_action_env=CXX=clang++

# Mirror cvm's relaxations (BCR m4/flex/bison gnulib, googletest deprecated
# std::get_temporary_buffer under libstdc++ 12).
build --copt=-Wno-error=implicit-function-declaration --host_copt=-Wno-error=implicit-function-declaration

# -Wall / -Werror only on first-party rv_tester code.
build --per_file_copt=-external/.*@-Wall,-Werror,-Wno-error=deprecated-declarations

# TODO(open-source): bring back the clang-tidy config once a public clang-tidy
# aspect lands.
# build:clang-tidy --@bazel_clang_tidy//:clang_tidy_config=@rv_tester//:clang_tidy_config
# build:clang-tidy --aspects_parameters=clang_tidy_repository=rv_tester

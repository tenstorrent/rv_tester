load("@rules_hdl//verilog:providers.bzl", "verilog_library")

verilog_library(
    name = "sysmod_pkg",
    srcs = ["sysmod_pkg.sv"],
    visibility = ["//visibility:public"],
)

verilog_library(
    name = "sysmod",
    srcs = ["sysmod.sv"],
    deps = [
        ":sysmod_pkg",
        "@cvm//:plusargs_sv",
    ],
    visibility = ["//:__pkg__"],
)

cc_library(
    name = "device",
    hdrs = ["device.h"],
    strip_include_prefix = "//sysmod",
    visibility = ["//visibility:public"],
)

cc_library(
    name = "sysmod_dpi",
    srcs = [
      "sysmod.cpp",
    ],
    hdrs = [
      "sysmod.h",
      "device.h",
    ],
    deps = [
      "//common:common",
      "//sysmod/clint:clint",
      "//sysmod/trickbox:trickbox",
      "//sysmod/htif:htif",
      "//sysmod/mem:mem",
      "@cvm//:plusargs",
    ],
    alwayslink = True,
    visibility = ["//:__pkg__"],
)
